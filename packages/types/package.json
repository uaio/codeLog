    "codelog",
    "types",
    "typescript",
    "mobile-debugging",
    "logging"
  ],
  "author": "codeLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/codeLog.git",
    "directory": "packages/types"
  },
