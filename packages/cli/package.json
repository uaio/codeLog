{
  "name": "@codelog/cli",
  "version": "0.2.1",
  "description": "CLI for codeLog — start server, configure AI tools, one-command setup",
  "keywords": [
    "codelog",
    "cli",
    "mobile-debugging",
    "mcp",
    "claude",
    "cursor",
    "devtools"
  ],
  "author": "codeLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/codeLog.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/uaio/codeLog/tree/main/packages/cli",
  "type": "module",
  "bin": {
    "codelog": "./bin/codelog.js"
  },
  "files": [
    "bin",
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist public",
    "prebuild": "npm run clean",
    "build": "tsc && npm run copy-web",
    "copy-web": "node scripts/copy-web.cjs",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@codelog/mcp": "workspace:*",
    "@codelog/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
